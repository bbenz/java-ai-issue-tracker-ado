# Azure DevOps settings
ADO_ORG=your-ado-org
ADO_PROJECT=your-ado-project
ADO_QUERY_ID=your-saved-query-guid
# Personal Access Token (fallback if az login is unavailable)
ADO_PAT=
# Custom field name that holds "SpringAI" or "LangChain4j" (auto-detected if blank)
ADO_PROJECT_FIELD=
# Assign resolved work items to this user
ADO_ASSIGN_TO=Your Name <you@example.com>

# GitHub personal access token (recommended to avoid rate limits)
GITHUB_TOKEN=

# Target project versions (comma-separated key:value pairs)
TARGETS=langchain4j:1.12.2,spring-ai:1.1.4
